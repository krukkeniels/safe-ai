#!/bin/bash
# safe-ai pre-push hook
# Prompts for confirmation before pushing from inside the sandbox.
# Install: git config core.hooksPath /path/to/config/git

remote="$1"
url="$2"

echo ""
echo "=== safe-ai: Push gate ==="
echo "Remote: $remote ($url)"
echo ""

# Show what will be pushed
while read local_ref local_oid remote_ref remote_oid; do
    echo "  $local_ref -> $remote_ref"
done

echo ""
read -r -p "Allow this push? [y/N] " response
case "$response" in
    [yY][eE][sS]|[yY])
        exit 0
        ;;
    *)
        echo "Push blocked by safe-ai pre-push hook."
        exit 1
        ;;
esac
